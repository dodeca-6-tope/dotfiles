shell-integration-features = ssh-terminfo,ssh-env,no-cursor
font-family = SF Mono
font-style = Regular
font-size = 18
font-thicken = true
theme = light:Apple System Colors Light,dark:Ghostty Default Style Dark
window-theme = auto
cursor-style = block
keybind = page_up=scroll_page_up
keybind = page_down=scroll_page_down
